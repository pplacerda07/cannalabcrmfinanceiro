generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
}

enum PatientStatus {
  NOVO_LEAD
  EM_ATENDIMENTO
  PAGAMENTO_ENVIADO
  PAGO
  CONSULTA_AGENDADA
  CONSULTA_REALIZADA
  DOCUMENTO_ANEXADO
  FINALIZADO
  PERDIDO
}

enum PaymentLinkStatus {
  PENDING
  CONFIRMED
  OVERDUE
  CANCELLED
}

enum AppointmentStatus {
  SCHEDULED
  DONE
  CANCELLED
}

enum DocumentType {
  RECEITA
  RELATORIO_MEDICO
  EXAME
  DOCUMENTO_PESSOAL
  ORIENTACAO_ANVISA
  OUTRO
}

enum TemplateFieldType {
  TEXT_SHORT
  TEXT_LONG
  SELECT
  MULTI_SELECT
  DATE
  YES_NO
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patients             Patient[]
  templateSubmissions  TemplateSubmission[]
  documents            Document[]
  activityLogs         ActivityLog[]
}

model Patient {
  id           String        @id @default(cuid())
  name         String
  whatsapp     String
  email        String?
  cpf          String?
  state        String?
  condition    String
  notes        String?
  status       PatientStatus @default(NOVO_LEAD)
  assignedTo   User?         @relation(fields: [assignedToId], references: [id])
  assignedToId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  appointments        Appointment[]
  paymentLinks        PaymentLink[]
  templateSubmissions TemplateSubmission[]
  documents           Document[]
  activityLogs        ActivityLog[]
}

model Appointment {
  id            String            @id @default(cuid())
  patient       Patient           @relation(fields: [patientId], references: [id])
  patientId     String
  startsAt      DateTime
  endsAt        DateTime
  status        AppointmentStatus @default(SCHEDULED)
  googleEventId String?
  googleMeetUrl String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model PaymentLink {
  id                 String            @id @default(cuid())
  patient            Patient           @relation(fields: [patientId], references: [id])
  patientId          String
  asaasPaymentLinkId String?
  url                String?
  value              Float
  description        String?
  status             PaymentLinkStatus @default(PENDING)
  externalReference  String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  events PaymentEvent[]
}

model PaymentEvent {
  id            String      @id @default(cuid())
  paymentLink   PaymentLink @relation(fields: [paymentLinkId], references: [id])
  paymentLinkId String
  asaasEventId  String?
  eventType     String
  payload       Json
  receivedAt    DateTime    @default(now())
}

model Template {
  id          String    @id @default(cuid())
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  fields      TemplateField[]
  submissions TemplateSubmission[]
}

model TemplateField {
  id         String            @id @default(cuid())
  template   Template          @relation(fields: [templateId], references: [id])
  templateId String
  label      String
  type       TemplateFieldType
  options    Json?
  required   Boolean           @default(false)
  order      Int               @default(0)

  answers TemplateAnswer[]
}

model TemplateSubmission {
  id          String    @id @default(cuid())
  template    Template  @relation(fields: [templateId], references: [id])
  templateId  String
  patient     Patient   @relation(fields: [patientId], references: [id])
  patientId   String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  answers TemplateAnswer[]
}

model TemplateAnswer {
  id           String             @id @default(cuid())
  submission   TemplateSubmission @relation(fields: [submissionId], references: [id])
  submissionId String
  field        TemplateField      @relation(fields: [fieldId], references: [id])
  fieldId      String
  value        String?
}

model Document {
  id           String       @id @default(cuid())
  patient      Patient      @relation(fields: [patientId], references: [id])
  patientId    String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  uploadedById String
  type         DocumentType @default(OUTRO)
  fileName     String
  mimeType     String
  storageKey   String
  size         Int
  createdAt    DateTime     @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  patient   Patient  @relation(fields: [patientId], references: [id])
  patientId String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
}

model IntegrationCredential {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
